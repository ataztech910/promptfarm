{
  "name": "@promptfarm/cli",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "bin": {
    "promptfarm": "./dist/index.cjs"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:cli-runtime && npm run test:runtime-polish && npm run test:integration",
    "validate": "tsx src/main.ts validate",
    "resolve": "tsx src/main.ts resolve",
    "doctor": "tsx src/main.ts doctor",
    "evaluate": "tsx src/main.ts evaluate",
    "blueprint": "tsx src/main.ts blueprint",
    "build:prompts": "tsx src/main.ts build",
    "list": "tsx src/main.ts list",
    "render": "tsx src/main.ts render",
    "test:integration": "node --import tsx --test src/commands/evaluate.integration.test.ts src/commands/blueprint.integration.test.ts src/commands/build.integration.test.ts src/commands/resolve.integration.test.ts src/commands/doctor.integration.test.ts",
    "test:cli-runtime": "node --import tsx --test src/commands/runtimeCli.integration.test.ts",
    "test:runtime-polish": "node --import tsx --test src/commands/resolve.integration.test.ts src/commands/doctor.integration.test.ts"
  },
  "dependencies": {
    "@promptfarm/core": "workspace:*",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.0"
  },
  "license": "PolyForm-Noncommercial-1.0.0"
}
