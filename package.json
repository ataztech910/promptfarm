{
  "name": "promptfarm-workspace",
  "private": true,
  "version": "0.5.0",
  "description": "PromptFarm monorepo workspace",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "npm --prefix packages/core run build && npm --prefix packages/cli run build",
    "typecheck": "npm --prefix packages/core run typecheck && npm --prefix packages/cli run typecheck && npx tsc --noEmit",
    "test": "npm --prefix packages/core run test && npm --prefix packages/cli run test",
    "serve": "npm --prefix packages/cli run serve",
    "validate": "node bin/promptfarm.cjs validate",
    "resolve": "node bin/promptfarm.cjs resolve",
    "doctor": "node bin/promptfarm.cjs doctor",
    "evaluate": "node bin/promptfarm.cjs evaluate",
    "blueprint": "node bin/promptfarm.cjs blueprint",
    "build:prompts": "node bin/promptfarm.cjs build",
    "list": "node bin/promptfarm.cjs list",
    "render": "node bin/promptfarm.cjs render",
    "test:composition": "npm --prefix packages/core run test:composition",
    "test:integration": "npm --prefix packages/core run test:integration",
    "test:evaluation": "npm --prefix packages/core run test:evaluation",
    "test:blueprint": "npm --prefix packages/core run test:blueprint",
    "test:builders": "npm --prefix packages/core run test:builders",
    "test:cli-runtime": "npm --prefix packages/cli run test:cli-runtime",
    "test:runtime-polish": "npm --prefix packages/cli run test:runtime-polish",
    "cli": "node bin/promptfarm.cjs",
    "studio:dev": "npm --prefix apps/studio run dev",
    "studio:build": "npm --prefix apps/studio run build",
    "studio:serve": "npm run studio:build && npm --prefix packages/cli run serve",
    "editor:dev": "npm --prefix apps/studio run dev",
    "editor:build": "npm --prefix apps/studio run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.0"
  },
  "license": "PolyForm-Noncommercial-1.0.0"
}
