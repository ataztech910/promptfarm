{
  "name": "promptfarm",
  "version": "0.2.2",
  "description": "Prompt infrastructure for engineering teams",
  "type": "module",
  "bin": {
    "promptfarm": "./bin/promptfarm.cjs"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ataztech910/promptfarm"
  },
  "homepage": "https://github.com/ataztech910/promptfarm",
  "keywords": [
    "prompt",
    "ai",
    "llm",
    "prompt-engineering",
    "developer-tools",
    "cli",
    "typescript"
  ],
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "validate": "tsx src/cli/index.ts validate",
    "build:prompts": "tsx src/cli/index.ts build",
    "list": "tsx src/cli/index.ts list",
    "render": "tsx src/cli/index.ts render"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "fast-glob": "^3.3.2",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.0"
  }
}